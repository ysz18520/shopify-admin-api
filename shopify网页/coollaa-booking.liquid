<script>
(function() {
  const sectionId = '{{ section.id }}';
  const API_BASE = '{{ api_base }}';
  const MEETING_TYPE = '{{ section.settings.meeting_type | escape }}';

  // ==================== State ====================
  let currentYear = new Date().getFullYear();
  let currentMonth = new Date().getMonth();
  let selectedDate = null;
  let selectedDuration = 30;
  let selectedTimeSlot = null;
  let businessTimezone = 'Asia/Shanghai';
  let lastBookingId = null;
  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

  // ==================== DOM References ====================
  function $(id) { return document.getElementById(id + '-' + sectionId); }

  // ==================== Calendar ====================
  function renderCalendar() {
    const firstDay = new Date(currentYear, currentMonth, 1);
    const lastDay = new Date(currentYear, currentMonth + 1, 0);
    const startOffset = (firstDay.getDay() + 6) % 7;

    $('monthYear').textContent = monthNames[currentMonth] + ' ' + currentYear;

    let html = '';
    for (let i = 0; i < startOffset; i++) {
      html += '<div class="day empty"></div>';
    }

    const today = new Date();
    const todayStr = formatDate(today);

    for (let d = 1; d <= lastDay.getDate(); d++) {
      const dateStr = formatDate(new Date(currentYear, currentMonth, d));
      const dayOfWeek = new Date(currentYear, currentMonth, d).getDay();
      const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;
      const isPast = dateStr < todayStr;
      const isSelected = dateStr === selectedDate;
      const isToday = dateStr === todayStr;

      let cls = 'day';
      if (isSelected) cls += ' selected';
      if (isToday) cls += ' today';
      if (isWeekend || isPast) cls += ' disabled';

      if (isWeekend || isPast) {
        html += '<div class="' + cls + '">' + d + '</div>';
      } else {
        html += '<div class="' + cls + '" onclick="window._booking' + sectionId.replace(/-/g, '_') + '.selectDate(\'' + dateStr + '\')">' + d + '</div>';
      }
    }

    $('calendarDays').innerHTML = html;
  }

  function changeMonth(delta) {
    currentMonth += delta;
    if (currentMonth > 11) { currentMonth = 0; currentYear++; }
    if (currentMonth < 0) { currentMonth = 11; currentYear--; }
    renderCalendar();
  }

  function selectDate(dateStr) {
    selectedDate = dateStr;
    selectedTimeSlot = null;
    renderCalendar();
    $('selectedDateLabel').textContent = dateStr;
    loadTimeSlots();
  }

  function formatDate(d) {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return y + '-' + m + '-' + day;
  }

  // ==================== Timezone Selector ====================
  const TIMEZONES = [
    { value: 'Pacific/Tongatapu', label: 'UTC +13:00  -  Tonga' },
    { value: 'Pacific/Apia', label: 'UTC +13:00  -  Samoa' },
    { value: 'Pacific/Auckland', label: 'UTC +12:00  -  Auckland, New Zealand' },
    { value: 'Pacific/Fiji', label: 'UTC +12:00  -  Fiji' },
    { value: 'Pacific/Chatham', label: 'UTC +12:45  -  Chatham Islands' },
    { value: 'Pacific/Guadalcanal', label: 'UTC +11:00  -  Solomon Islands' },
    { value: 'Pacific/Noumea', label: 'UTC +11:00  -  New Caledonia' },
    { value: 'Pacific/Norfolk', label: 'UTC +11:00  -  Norfolk Island' },
    { value: 'Australia/Sydney', label: 'UTC +10:00  -  Sydney, Australia' },
    { value: 'Australia/Adelaide', label: 'UTC +09:30  -  Adelaide, Australia' },
    { value: 'Asia/Tokyo', label: 'UTC +09:00  -  Tokyo, Japan' },
    { value: 'Asia/Seoul', label: 'UTC +09:00  -  Seoul, South Korea' },
    { value: 'Australia/Perth', label: 'UTC +08:00  -  Perth, Australia' },
    { value: 'Asia/Shanghai', label: 'UTC +08:00  -  China, Hong Kong, Singapore' },
    { value: 'Asia/Hong_Kong', label: 'UTC +08:00  -  China, Hong Kong, Singapore' },
    { value: 'Asia/Singapore', label: 'UTC +08:00  -  China, Hong Kong, Singapore' },
    { value: 'Asia/Taipei', label: 'UTC +08:00  -  Taipei, Taiwan' },
    { value: 'Asia/Bangkok', label: 'UTC +07:00  -  Bangkok, Thailand' },
    { value: 'Asia/Yangon', label: 'UTC +06:30  -  Yangon, Myanmar' },
    { value: 'Asia/Dhaka', label: 'UTC +06:00  -  Dhaka, Bangladesh' },
    { value: 'Asia/Kathmandu', label: 'UTC +05:45  -  Kathmandu, Nepal' },
    { value: 'Asia/Kolkata', label: 'UTC +05:30  -  Mumbai, India' },
    { value: 'Asia/Karachi', label: 'UTC +05:00  -  Karachi, Pakistan' },
    { value: 'Asia/Kabul', label: 'UTC +04:30  -  Kabul, Afghanistan' },
    { value: 'Asia/Dubai', label: 'UTC +04:00  -  Dubai, UAE' },
    { value: 'Asia/Tbilisi', label: 'UTC +04:00  -  Tbilisi, Georgia' },
    { value: 'Asia/Tehran', label: 'UTC +03:30  -  Tehran, Iran' },
    { value: 'Asia/Baghdad', label: 'UTC +03:00  -  Baghdad, Iraq' },
    { value: 'Asia/Riyadh', label: 'UTC +03:00  -  Riyadh, Saudi Arabia' },
    { value: 'Europe/Istanbul', label: 'UTC +03:00  -  Istanbul, Turkey' },
    { value: 'Africa/Nairobi', label: 'UTC +03:00  -  Nairobi, Kenya' },
    { value: 'Asia/Jerusalem', label: 'UTC +02:00  -  Jerusalem, Israel' },
    { value: 'Africa/Cairo', label: 'UTC +02:00  -  Cairo, Egypt' },
    { value: 'Africa/Khartoum', label: 'UTC +02:00  -  Khartoum, Sudan' },
    { value: 'Europe/Athens', label: 'UTC +02:00  -  Athens, Greece' },
    { value: 'Africa/Lagos', label: 'UTC +01:00  -  Lagos, Nigeria' },
    { value: 'Europe/Berlin', label: 'UTC +01:00  -  Berlin, Germany' },
    { value: 'Europe/Zurich', label: 'UTC +01:00  -  Zurich, Switzerland' },
    { value: 'Europe/Stockholm', label: 'UTC +01:00  -  Stockholm, Sweden' },
    { value: 'Europe/Warsaw', label: 'UTC +01:00  -  Warsaw, Poland' },
    { value: 'Africa/Accra', label: 'UTC +00:00  -  Accra, Ghana' },
    { value: 'Europe/London', label: 'UTC +00:00  -  London, UK' },
    { value: 'Atlantic/Azores', label: 'UTC -01:00  -  Azores, Portugal' },
    { value: 'America/St_Johns', label: "UTC -02:30  -  St. John's, Canada" },
    { value: 'America/Halifax', label: 'UTC -03:00  -  Halifax, Canada' },
    { value: 'America/Sao_Paulo', label: 'UTC -03:00  -  Sao Paulo, Brazil' },
    { value: 'America/Asuncion', label: 'UTC -03:00  -  Asuncion, Paraguay' },
    { value: 'America/New_York', label: 'UTC -04:00  -  New York, USA' },
    { value: 'America/Caracas', label: 'UTC -04:00  -  Caracas, Venezuela' },
    { value: 'America/Guyana', label: 'UTC -04:00  -  Georgetown, Guyana' },
    { value: 'America/Chicago', label: 'UTC -05:00  -  Chicago, USA' },
    { value: 'America/Lima', label: 'UTC -05:00  -  Lima, Peru' },
    { value: 'America/Denver', label: 'UTC -06:00  -  Denver, USA' },
    { value: 'America/Edmonton', label: 'UTC -06:00  -  Edmonton, Canada' },
    { value: 'America/Los_Angeles', label: 'UTC -07:00  -  Los Angeles, USA' },
    { value: 'America/Phoenix', label: 'UTC -07:00  -  Phoenix, USA' },
    { value: 'America/Anchorage', label: 'UTC -08:00  -  Anchorage, USA' },
    { value: 'Pacific/Honolulu', label: 'UTC -10:00  -  Honolulu, USA' },
    { value: 'Pacific/Midway', label: 'UTC -11:00  -  Midway Atoll' },
    { value: 'Pacific/Pago_Pago', label: 'UTC -11:00  -  Pago Pago, American Samoa' },
  ];

  let selectedTimezone = 'Asia/Shanghai';

  function renderTimezoneList(filter) {
    const listEl = $('timezoneList');
    const lowerFilter = (filter || '').toLowerCase();
    const filtered = TIMEZONES.filter(function(tz) { return tz.label.toLowerCase().includes(lowerFilter); });

    if (filtered.length === 0) {
      listEl.innerHTML = '<div class="custom-select-item empty">No results found</div>';
      return;
    }

    let html = '';
    filtered.forEach(function(tz) {
      const isSelected = tz.value === selectedTimezone;
      html += '<div class="custom-select-item ' + (isSelected ? 'selected' : '') + '" data-value="' + tz.value + '" onclick="window._booking' + sectionId.replace(/-/g, '_') + '.selectTimezone(\'' + tz.value + '\')">' + tz.label + '</div>';
    });
    listEl.innerHTML = html;
  }

  function toggleTimezoneDropdown() {
    const dropdown = $('timezoneDropdown');
    const trigger = $('timezoneTrigger');
    const isOpen = dropdown.classList.contains('open');

    if (isOpen) {
      closeTimezoneDropdown();
    } else {
      dropdown.classList.add('open');
      trigger.classList.add('active');
      $('timezoneSearch').value = '';
      renderTimezoneList();
      setTimeout(function() { $('timezoneSearch').focus(); }, 50);
    }
  }

  function closeTimezoneDropdown() {
    $('timezoneDropdown').classList.remove('open');
    $('timezoneTrigger').classList.remove('active');
  }

  function filterTimezones(e) {
    renderTimezoneList(e.target.value);
  }

  function selectTimezone(value) {
    selectedTimezone = value;
    const tz = TIMEZONES.find(function(t) { return t.value === value; });
    $('timezoneTriggerText').textContent = tz ? tz.label : value;

    const nativeSelect = $('timezoneSelect');
    nativeSelect.value = value;

    closeTimezoneDropdown();
    onTimezoneChange();
  }

  // Close on outside click
  document.addEventListener('click', function(e) {
    const wrapper = $('timezoneSelectWrapper');
    if (wrapper && !wrapper.contains(e.target)) {
      closeTimezoneDropdown();
    }
  });

  // ==================== Duration Selection ====================
  function selectDuration(minutes) {
    selectedDuration = minutes;
    document.querySelectorAll('.coollaa-booking-section[data-section-id="' + sectionId + '"] .duration-option').forEach(function(btn) {
      btn.classList.toggle('active', parseInt(btn.dataset.duration) === minutes);
    });
    if (selectedDate) loadTimeSlots();
  }

  function onTimezoneChange() {
    if (selectedDate) loadTimeSlots();
  }

  // ==================== Load Available Slots ====================
  async function loadTimeSlots() {
    if (!selectedDate) return;

    const timezone = $('timezoneSelect').value;
    const listEl = $('timeList');
    listEl.innerHTML = '<div class="time-empty">Loading...</div>';

    try {
      const res = await fetch(
        API_BASE + '/coollaa/booking/slots?date=' + selectedDate + '&duration=' + selectedDuration + '&timezone=' + encodeURIComponent(timezone)
      );
      const data = await res.json();

      if (!data.slots || data.slots.length === 0) {
        listEl.innerHTML = '<div class="time-empty">No available slots for this date</div>';
        return;
      }

      let html = '';
      data.slots.forEach(function(slot) {
        const isSelected = selectedTimeSlot && selectedTimeSlot.utc === slot.utc;
        html += '<div class="time-item ' + (isSelected ? 'selected' : '') + '" data-utc="' + slot.utc + '" data-local="' + slot.localTime + '" onclick="window._booking' + sectionId.replace(/-/g, '_') + '.selectTimeSlot(\'' + slot.utc + '\', \'' + slot.localTime + '\')">' + slot.localTime + '</div>';
      });
      listEl.innerHTML = html;
    } catch (err) {
      listEl.innerHTML = '<div class="time-empty" style="color: #e53935;">Failed to load. Please refresh and try again.</div>';
      console.error(err);
    }
  }

  function selectTimeSlot(utc, localTime) {
    selectedTimeSlot = { utc: utc, localTime: localTime };
    document.querySelectorAll('.coollaa-booking-section[data-section-id="' + sectionId + '"] .time-item').forEach(function(el) {
      el.classList.toggle('selected', el.dataset.utc === utc);
    });
    goToStep2();
  }

  // ==================== Step Switching ====================
  function switchPanel(step) {
    const card = $('booking-card');
    const p1 = $('panel-step1');
    const p2 = $('panel-step2');
    const p3 = $('panel-success');

    if (step === 1) {
      card.classList.remove('step-form');
      setTimeout(function() {
        p1.classList.remove('hidden');
        p2.classList.add('hidden');
        p3.classList.add('hidden');
      }, 50);
    } else if (step === 2) {
      card.classList.add('step-form');
      setTimeout(function() {
        p1.classList.add('hidden');
        p2.classList.remove('hidden');
        p3.classList.add('hidden');
      }, 50);
    } else if (step === 3) {
      card.classList.add('step-form');
      setTimeout(function() {
        p1.classList.add('hidden');
        p2.classList.add('hidden');
        p3.classList.remove('hidden');
      }, 50);
    }
  }

  function goToStep1() {
    switchPanel(1);
    updateStepIndicator(1);
  }

  function goToStep2() {
    if (!selectedDate || !selectedTimeSlot) return;

    const timezone = $('timezoneSelect').value;
    const dateObj = new Date(selectedTimeSlot.utc);
    const timeStr = dateObj.toLocaleString('en-US', {
      timeZone: timezone,
      year: 'numeric', month: 'long', day: 'numeric',
      weekday: 'long', hour: '2-digit', minute: '2-digit', hour12: false
    });

    $('formDateTime').textContent = timeStr;
    switchPanel(2);
    updateStepIndicator(2);
  }

  function updateStepIndicator(step) {
    const s1 = $('step1-indicator');
    const s2 = $('step2-indicator');
    const line = $('step-line');

    if (step === 1) {
      s1.className = 'step active';
      s2.className = 'step';
      line.className = 'step-line';
    } else {
      s1.className = 'step done';
      s2.className = 'step active';
      line.className = 'step-line done';
    }
  }

  // ==================== Submit Form ====================
  async function submitForm(e) {
    e.preventDefault();
    if (!selectedDate || !selectedTimeSlot) return;

    const btn = $('submitBtn');
    btn.disabled = true;
    btn.textContent = 'Submitting...';

    const form = e.target;
    const timezone = $('timezoneSelect').value;

    const utcDate = new Date(selectedTimeSlot.utc);
    const merchantTimeStr = utcDate.toLocaleString('en-US', {
      timeZone: businessTimezone,
      hour12: false, hour: '2-digit', minute: '2-digit'
    });

    const payload = {
      date: selectedDate,
      startTime: merchantTimeStr,
      duration: selectedDuration,
      userTimezone: timezone,
      lastName: form.lastName.value,
      firstName: form.firstName.value || undefined,
      email: form.email.value || undefined,
      company: form.company.value,
      phone: form.phone.value,
      meetingType: MEETING_TYPE || 'WhatsApp Call',
    };

    try {
      const res = await fetch(API_BASE + '/coollaa/booking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await res.json();

      if (res.ok) {
        lastBookingId = data.id;
        $('successTime').textContent = $('formDateTime').textContent;
        switchPanel(3);
        updateStepIndicator(2);
      } else {
        alert(data.error || 'Booking failed. Please try again.');
      }
    } catch (err) {
      alert('Network error. Please check if the service is running.');
      console.error(err);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Confirm';
    }
  }

  async function cancelBooking() {
    if (!lastBookingId) {
      alert('Unable to cancel: booking not found.');
      return;
    }
    if (!confirm('Are you sure you want to cancel this booking?')) return;

    try {
      const res = await fetch(API_BASE + '/coollaa/booking/' + lastBookingId + '/cancel', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
      });
      if (res.ok) {
        alert('Booking cancelled');
        resetBooking();
      } else {
        const data = await res.json();
        alert(data.error || 'Cancellation failed.');
      }
    } catch (err) {
      alert('Network error. Please check if the service is running.');
      console.error(err);
    }
  }

  function resetBooking() {
    selectedDate = null;
    selectedTimeSlot = null;
    lastBookingId = null;
    $('bookingForm').reset();
    $('timeList').innerHTML = '<div class="time-empty">Please select a date first</div>';
    $('selectedDateLabel').textContent = 'Please select a date';
    goToStep1();
    renderCalendar();
  }

  // ==================== Init ====================
  renderCalendar();

  // Set default timezone label on trigger
  const defaultTz = TIMEZONES.find(function(t) { return t.value === selectedTimezone; });
  if (defaultTz) {
    $('timezoneTriggerText').textContent = defaultTz.label;
  }

  // Auto-select today
  selectDate(formatDate(new Date()));

  // Fetch merchant config (timezone, etc.)
  fetch(API_BASE + '/coollaa/booking/config')
    .then(function(r) { return r.json(); })
    .then(function(config) {
      businessTimezone = config.timeZone || 'Asia/Shanghai';
    })
    .catch(function() {
      console.warn('Unable to load config, using defaults.');
    });

  // Expose global methods for onclick handlers
  const ns = '_booking' + sectionId.replace(/-/g, '_');
  window[ns] = {
    selectDate: selectDate,
    selectTimezone: selectTimezone,
    selectTimeSlot: selectTimeSlot,
    changeMonth: changeMonth,
    selectDuration: selectDuration,
    toggleTimezoneDropdown: toggleTimezoneDropdown,
    filterTimezones: filterTimezones,
    onTimezoneChange: onTimezoneChange,
    goToStep1: goToStep1,
    goToStep2: goToStep2,
    submitForm: submitForm,
    cancelBooking: cancelBooking,
    resetBooking: resetBooking,
  };
})();
</script>

</div>

