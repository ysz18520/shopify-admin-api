{%- liquid
  assign limit = section.settings.display_limit | default: 12
  assign current_site = section.settings.site | default: 'default'

  # 根据 site 过滤数据
  assign all_entries = metaobjects.vote.values | where: 'site', current_site
  assign all_series = ''
  for entry in all_entries
    unless all_series contains entry.series
      if all_series == ''
        assign all_series = entry.series
      else
        assign all_series = all_series | append: ',' | append: entry.series
      endif
    endunless
  endfor
  assign series_array = all_series | split: ','
  assign sorted_entries = all_entries | sort: 'voting_count' | reverse
-%}

{% comment %} 字体（非阻塞加载） {% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Luckiest+Guy&family=Fredoka:wght@400;500;600;700&family=Nunito:wght@600;700;800;900&display=swap"
  rel="stylesheet"
  media="print"
  onload="this.media='all'"
>
<noscript>
  <link
    href="https://fonts.googleapis.com/css2?family=Luckiest+Guy&family=Fredoka:wght@400;500;600;700&family=Nunito:wght@600;700;800;900&display=swap"
    rel="stylesheet"
  >
</noscript>

<div class="design-community-section section-{{ section.id }}">
  <!-- 列表页容器 -->
  <div id="galleryView" class="view-container active">
    <!-- 主标题区域 -->
    <section class="hero">
      <h1>{{ section.settings.hero_title | default: '社区设计' }}</h1>
      <p>
        {{ section.settings.hero_description | default: '发现来自创意社区的精彩玩具设计' }}
      </p>

      <!-- 自动轮播 + 波浪错落 + 果冻入场（已修复遮挡背景问题） -->
      <div class="auto-slider-section" style="margin:20px 0 64px;">
        <h2 style="text-align:center; font-family:'Fredoka',sans-serif; font-size:2.6rem; font-weight:700; margin-bottom:40px; position:relative; z-index:2;">
          最高设计票数
        </h2>

        <!-- 新增一个专门负责裁切的容器 -->
        <div style="overflow:hidden; border-radius:32px; position:relative; z-index:1;">
          <div class="auto-slider-track">
            {%- assign waveOrder = '0,1,2,1,0' | split: ',' -%}
            {%- assign waveIndex = 0 -%}

            {%- for copy in (1..2) -%}
              {%- for entry in sorted_entries limit: 24 -%}
                {%- assign sizeIdx = waveOrder[waveIndex] | plus: 0 -%}
                {%- if sizeIdx == 0 -%}
                  {%- assign cardW = 240 -%}
                  {%- assign cardH = 284 -%}
                  {%- assign waveVal = 80 -%}
                {%- elsif sizeIdx == 1 -%}
                  {%- assign cardW = 216 -%}
                  {%- assign cardH = 256 -%}
                  {%- assign waveVal = 30 -%}
                {%- else -%}
                  {%- assign cardW = 192 -%}
                  {%- assign cardH = 228 -%}
                  {%- assign waveVal = -20 -%}
                {%- endif -%}

                {%- assign delayIndex = waveIndex | modulo: 5 -%}
                {%- assign delay = 0.3 | plus: delayIndex | times: 0.25 | round: 2 -%}

                <div
                  class="auto-slide-card"
                  style="--wave:{{waveVal}}; --card-w:{{cardW}}px; --card-h:{{cardH}}px; --index:{{delay}};"
                  onclick="openModal('{{ entry.design_id }}')"
                >
                  <div style="text-decoration:none;color:inherit;cursor:pointer;">
                    <div class="auto-img">
                      {%- if entry.design_img -%}
                        {{ entry.design_img | image_url: width: 600 | image_tag: loading: 'lazy', class: 'cover' }}
                      {%- else -%}
                        <div class="placeholder">暂无图片</div>
                      {%- endif -%}
                    </div>
                    <div class="card-footer">
                      <div class="author-info">
                        <div class="author-avatar">{{ entry.author | truncate: 'kk' }}</div>
                        <span class="author-name">{{ entry.design_title | truncate: 36 }}</span>
                      </div>
                      <div class="vote-badge" onclick="event.stopPropagation(); openModal('{{ entry.design_id }}')">
                        <span class="vote-icon">♥</span>
                        <span class="vote-count">{{ entry.voting_count | default: 0 }}</span>
                      </div>
                    </div>
                  </div>
                </div>

                {%- assign waveIndex = waveIndex | plus: 1 -%}
                {%- assign waveIndex = waveIndex | modulo: 5 -%}
              {%- endfor -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      {% comment %} 系列筛选标签 {% endcomment %}
      <div class="filter-section">
        <div class="filter-tabs" id="filterTabs">
          <button class="filter-tab active" data-filter="all">全部设计</button>
          {%- for series in series_array -%}
            {%- unless series == blank -%}
              <button class="filter-tab" data-filter="{{ series }}">{{ series }}</button>
            {%- endunless -%}
          {%- endfor -%}
        </div>

        {%- if series_array.size > 12 -%}
          <div class="filter-tabs hidden" id="moreFilterTabs">
            {%- for series in series_array offset: 12 -%}
              {%- unless series == blank -%}
                <button class="filter-tab" data-filter="{{ series }}">{{ series }}</button>
              {%- endunless -%}
            {%- endfor -%}
          </div>
          <button class="expand-btn" id="expandBtn" onclick="toggleFilters()">
            <span id="expandText">查看更多</span>
            <svg
              id="expandIcon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
        {%- endif -%}
      </div>

      {% comment %} 加搜索功能 {% endcomment %}
      <div class="MeMie-toolbar">
        <!-- 搜索框组件 -->
        <div class="MeMie-search">
          <span class="MeMie-search-icon">🔍</span>
          <input
            type="text"
            class="MeMie-search-input"
            placeholder="搜索设计..."
            id="searchInput"
          >
        </div>

        <!-- 排序下拉框 -->
        <div class="MeMie-sort" id="sortDropdown">
          <div class="MeMie-sort-trigger" onclick="toggleSort()">
            <div class="MeMie-sort-label">
              <span class="MeMie-sort-caption">排序方式</span>
              <span class="MeMie-sort-value" id="sortValue">票数最高</span>
            </div>
            <span class="MeMie-sort-arrow">▲</span>
          </div>
          <div class="MeMie-sort-dropdown">
            <div class="MeMie-sort-option active" onclick="selectSort('votes-desc', '票数最高')">票数最高</div>
            <div class="MeMie-sort-option" onclick="selectSort('votes-asc', '票数最低')">票数最低</div>
            <div class="MeMie-sort-option" onclick="selectSort('title-asc', '标题 A-Z')">标题 A-Z</div>
            <div class="MeMie-sort-option" onclick="selectSort('title-desc', '标题 Z-A')">标题 Z-A</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 设计画廊 -->
    <div class="gallery">
      <div class="gallery-grid" id="galleryGrid">
        {%- if all_entries.size > 0 -%}
          {%- for entry in all_entries limit: limit -%}
            <div
              class="design-card"
              data-series="{{ entry.series }}"
              data-author="{{ entry.design_author }}"
              data-title="{{ entry.design_title }}"
              data-description="{{ entry.design_description }}"
              data-votes="{{ entry.voting_count | default: 0 }}"
              onclick="openModal('{{ entry.design_id }}')"
            >
              <div class="card-image">
                {%- if entry.design_img -%}
                  {{ entry.design_img | image_url: width: 500 | image_tag: loading: 'lazy', alt: entry.design_title }}
                {%- else -%}
                  <div class="placeholder-img">暂无图片</div>
                {%- endif -%}
              </div>
              <div class="card-content">
                <h3 class="card-title">{{ entry.design_title }}</h3>
                <div class="card-designer">
                  <span>👤</span>
                  <span>{{ entry.design_author }}</span>
                </div>
                <div class="card-footer">
                  <div class="like-count">
                    <span class="heart-icon"></span>
                    <span>{{ entry.voting_count | default: 0 }}</span>
                  </div>
                  <div class="view-badge">查看</div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          <p style="grid-column: 1/-1; text-align: center; padding: 60px 20px; opacity: 0.6;">
            暂无设计作品，请在元对象中添加设计内容
          </p>
        {%- endif -%}
      </div>

      <div id="noResults" class="no-results" style="display: none;">
        <p>未找到符合搜索条件的设计作品</p>
      </div>
    </div>
  </div>

  <!-- 详情页容器 -->
  <div id="designModal" class="modal-overlay">
    <div class="modal-content">
      <span class="modal-close" onclick="closeModal()">×</span>

      <div class="detail-layout">
        <!-- 头部信息栏 -->
        <div class="detail-header">
          <div class="detail-author">
            <div class="detail-author-avatar" id="detailAuthorAvatar">S</div>
            <div class="detail-author-info">
              <div class="detail-author-name" id="detailTitle"></div>
              <div class="detail-post-date">by <span id="detailAuthor"></span> · <span id="detailSeries"></span></div>
            </div>
          </div>
          <div class="detail-vote-count">
            <span class="detail-vote-count-icon">♥</span>
            <span id="detailVotes">0</span>
          </div>
        </div>

        <!-- 主图 -->
        <div class="detail-image">
          <img
            id="detailMainImage"
            src=""
            alt=""
            width="800"
            height="800"
            loading="lazy"
          >
        </div>

        <!-- 投票区域 -->
        <div class="detail-vote-section">
          <div class="detail-vote-question">想要这个设计变成现实吗？</div>
          <div class="detail-vote-form">
            <input
              type="email"
              id="vote-email"
              class="detail-vote-input"
              placeholder="输入邮箱进行投票"
            >
            <button type="button" class="detail-vote-btn" id="detailVoteBtn" onclick="prepareVote()">
              为它投票
            </button>
          </div>
        </div>

        <!-- 描述 -->
        <div class="detail-description">
          <p class="detail-description-text" id="detailDescription"></p>
          <div class="detail-tags" id="detailTags"></div>
        </div>
      </div>

      <!-- 相关设计 -->
      <div class="detail-related-section">
        <h3 class="detail-related-title">看看这些</h3>
        <div class="detail-related-grid" id="relatedGrid"></div>
      </div>

      <!-- 页脚声明 -->
      <div class="detail-footer-note">
        社区版块展示的设计和 artwork 仅供概念和说明用途。它们尚未经过相应知识产权 (IP) 所有者的审核、批准或认可。所有角色、品牌和商标的权利均归其各自所有者所有。这些设计不代表官方认可或授权的产品，除非获得所有必要方的正式批准。
      </div>
    </div>
  </div>
</div>
<script>
// ============== 数据初始化 ==============
window.designsData = [
    {%- for entry in all_entries -%}
    {
        designId: {{ entry.design_id | json }},
        title: {{ entry.design_title | json }},
        author: {{ entry.design_author | json }},
        series: {{ entry.series | json }},
        description: {{ entry.design_description.value | default: '' | json }},
        image: {{ entry.design_img | image_url: width: 800 | json }},
        votes: {{ entry.voting_count | default: 0 }},
        metaobjectHandle: {{ entry.handle | json }},  // ← 改用实际的 handle
        metaobjectId: {{ entry.id | json }}  // ← 添加 ID
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
];


// ============== 投票相关配置 ==============
const VOTE_COOLDOWN = 5000;
let lastVoteTime = 0;
let votedDesigns = JSON.parse(localStorage.getItem('votedDesigns') || '{}');

// 准备投票
function prepareVote() {
    const currentDesign = window.currentViewingDesign;
    if (!currentDesign) return;

    const now = Date.now();
    if (now - lastVoteTime < VOTE_COOLDOWN) {
        const remainingSeconds = Math.ceil((VOTE_COOLDOWN - (now - lastVoteTime)) / 1000);
        alert(`请等待 ${remainingSeconds} 秒后再投票`);
        return;
    }

    if (votedDesigns[currentDesign.designId]) {
        alert('您已经为该设计投过票了！');
        return;
    }

    const savedEmail = localStorage.getItem('voteEmail');
    
    if (savedEmail) {
        submitVote(savedEmail);
    } else {
        showEmailInput();
    }
}

// 显示邮箱输入框
function showEmailInput() {
    const emailInput = document.getElementById('vote-email');
    const voteBtn = document.getElementById('detailVoteBtn');

    emailInput.style.display = 'block';
    emailInput.focus();

    voteBtn.textContent = '提交投票';
    voteBtn.onclick = function() {
        const email = emailInput.value;
        if (email && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            localStorage.setItem('voteEmail', email);
            submitVote(email);
        } else {
            alert('请输入有效的邮箱地址');
        }
    };
}

// 提交投票
function submitVote(email) {
    const currentDesign = window.currentViewingDesign;
    const voteBtn = document.getElementById('detailVoteBtn');

    voteBtn.disabled = true;
    voteBtn.textContent = '投票中...';

    const cleanDesignId = currentDesign.designId.replace(/\s+/g, '-');
    const designTag = cleanDesignId + '-' + Math.floor(Date.now() / 1000);

    fetch('https://autumn-sky-dd18.analytics-556.workers.dev/', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            email: email,
            designTag: designTag
        })
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('Network error: ' + response.status);
        }
        return response.json();
    })
    .then(result => {
        if (result.success) {
            const newVotes = currentDesign.votes + 1;
            currentDesign.votes = newVotes;
            
            document.getElementById('detailVotes').textContent = newVotes.toLocaleString() + ' 票';
            
            document.querySelectorAll('.design-card').forEach(card => {
                const onclick = card.getAttribute('onclick');
                if (onclick && onclick.includes(currentDesign.designId)) {
                    const likeCountSpan = card.querySelector('.like-count span:last-child');
                    if (likeCountSpan) {
                        likeCountSpan.textContent = newVotes;
                    }
                    card.setAttribute('data-votes', newVotes);
                }
            });

            const dataIndex = window.designsData.findIndex(d => d.designId === currentDesign.designId);
            if (dataIndex !== -1) {
                window.designsData[dataIndex].votes = newVotes;
            }

            votedDesigns[currentDesign.designId] = true;
            localStorage.setItem('votedDesigns', JSON.stringify(votedDesigns));
            lastVoteTime = Date.now();

            voteBtn.textContent = '已投票 ✓';
            voteBtn.classList.add('voted');
            voteBtn.disabled = true;

            showVoteSuccess();
            
            setTimeout(() => {
                location.reload();
            }, 3000);
        } else {
            {% comment %} alert('投票失败：' + (result.error || '未知错误')); {% endcomment %}
            voteBtn.disabled = false;
            voteBtn.textContent = '为它投票';
        }
    })
    .catch(error => {
        console.error('Vote error:', error);
        {% comment %} alert('投票失败，请重试：' + error.message); {% endcomment %}
        voteBtn.disabled = false;
        voteBtn.textContent = '为它投票';
    });
}

// 显示投票成功动画
function showVoteSuccess() {
    const toast = document.createElement('div');
    toast.style.cssText = `
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) scale(0.8);
        background: #ff466f;
        color: white;
        padding: 20px 40px;
        border-radius: 20px;
        font-size: 1.2rem;
        font-weight: 700;
        font-family: 'Fredoka', sans-serif;
        z-index: 10000;
        opacity: 0;
        transition: all 0.3s;
        border: 4px solid white;
        box-shadow: 0 10px 0 rgba(0,0,0,0.2);
    `;
    toast.textContent = '✓ 投票成功！';
    document.body.appendChild(toast);

    requestAnimationFrame(() => {
        toast.style.opacity = '1';
        toast.style.transform = 'translate(-50%, -50%) scale(1)';
    });

    setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translate(-50%, -50%) scale(0.8)';
        setTimeout(() => toast.remove(), 300);
    }, 2000);
}

// ============== 筛选器展开/收起 ==============
function toggleFilters() {
    const moreFilters = document.getElementById('moreFilterTabs');
    const expandText = document.getElementById('expandText');
    const expandIcon = document.getElementById('expandIcon');
    
    if (moreFilters.classList.contains('hidden')) {
        moreFilters.classList.remove('hidden');
        expandText.textContent = '收起';
        expandIcon.style.transform = 'rotate(180deg)';
    } else {
        moreFilters.classList.add('hidden');
        expandText.textContent = '展开更多';
        expandIcon.style.transform = 'rotate(0deg)';
    }
}

// ============== 搜索功能 ==============
function handleSearch() {
    const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
    const cards = document.querySelectorAll('.design-card');
    let visibleCount = 0;

    cards.forEach(card => {
        const series = card.getAttribute('data-series').toLowerCase();
        const author = card.getAttribute('data-author').toLowerCase();
        const title = card.getAttribute('data-title').toLowerCase();
        const description = (card.getAttribute('data-description') || '').toLowerCase();

        if (searchTerm === '' ||
            series.includes(searchTerm) ||
            author.includes(searchTerm) ||
            title.includes(searchTerm) ||
            description.includes(searchTerm)) {
            card.style.display = 'block';
            visibleCount++;
        } else {
            card.style.display = 'none';
        }
    });

    document.getElementById('noResults').style.display = visibleCount === 0 ? 'block' : 'none';
}

// ============== 排序下拉框 ==============
function toggleSort() {
    document.getElementById('sortDropdown').classList.toggle('open');
}

function selectSort(value, label) {
    document.getElementById('sortValue').textContent = label;

    document.querySelectorAll('.MeMie-sort-option').forEach(opt => {
        opt.classList.remove('active');
    });
    event.target.classList.add('active');

    document.getElementById('sortDropdown').classList.remove('open');

    // 排序
    const grid = document.getElementById('galleryGrid');
    const cards = Array.from(document.querySelectorAll('.design-card'));

    cards.sort((a, b) => {
        switch(value) {
            case 'votes-desc':
                return parseInt(b.getAttribute('data-votes')) - parseInt(a.getAttribute('data-votes'));
            case 'votes-asc':
                return parseInt(a.getAttribute('data-votes')) - parseInt(b.getAttribute('data-votes'));
            case 'title-asc':
                return a.getAttribute('data-title').localeCompare(b.getAttribute('data-title'));
            case 'title-desc':
                return b.getAttribute('data-title').localeCompare(a.getAttribute('data-title'));
            default:
                return 0;
        }
    });

    cards.forEach(card => grid.appendChild(card));
}

// ============== Modal 打开/关闭 ==============
function openModal(designId) {
    const design = window.designsData.find(d => d.designId === designId);
    if (!design) {
        console.error('Design not found:', designId);
        return;
    }

    window.currentViewingDesign = design;

    document.getElementById('detailMainImage').src = design.image;
    document.getElementById('detailMainImage').alt = design.title;
    document.getElementById('detailTitle').textContent = design.title;
    document.getElementById('detailAuthor').textContent = design.author;
    document.getElementById('detailSeries').textContent = design.series + ' 系列';
    document.getElementById('detailVotes').textContent = design.votes.toLocaleString() + ' 票';

    // 作者头像首字母
    document.getElementById('detailAuthorAvatar').textContent = design.author ? design.author.charAt(0).toUpperCase() : '?';

    // 描述
    const rawDesc = design.description;
    let descriptionText = '暂无描述';
    if (rawDesc) {
        if (typeof rawDesc === 'string') {
            descriptionText = rawDesc;
        } else if (rawDesc && rawDesc.value !== undefined) {
            descriptionText = rawDesc.value;
        }
    }
    document.getElementById('detailDescription').textContent = descriptionText;

    const tagsHtml = `<span class="tag">${design.series} 系列</span><span class="tag">社区设计</span><span class="tag">限量版</span>`;
    document.getElementById('detailTags').innerHTML = tagsHtml;

    // 投票按钮状态
    const voteBtn = document.getElementById('detailVoteBtn');
    const emailInput = document.getElementById('vote-email');
    emailInput.style.display = 'none';
    emailInput.value = '';

    if (votedDesigns[design.designId]) {
        voteBtn.textContent = '已投票 ✓';
        voteBtn.classList.add('voted');
        voteBtn.disabled = true;
        voteBtn.style.background = '';
    } else {
        voteBtn.textContent = '为它投票';
        voteBtn.classList.remove('voted');
        voteBtn.style.background = '';
        voteBtn.disabled = false;
        voteBtn.onclick = prepareVote;
    }

    // 相关设计（3个）
    const related = window.designsData.filter(d => d.designId !== designId).slice(0, 3);
    const escapeHtml = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    const relatedHtml = related.map(d => `
        <div onclick="openModal('${d.designId}')" class="related-card">
            <div class="related-image"><img src="${d.image}" alt="${escapeHtml(d.title)}" loading="lazy"></div>
            <div class="related-info">
                <span class="related-title">${escapeHtml(d.title)}</span>
                <div class="related-likes"><span>♥</span><span>${d.votes}</span></div>
            </div>
        </div>
    `).join('');
    document.getElementById('relatedGrid').innerHTML = relatedHtml;

    document.getElementById('designModal').classList.add('active');
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    document.getElementById('designModal').classList.remove('active');
    document.body.style.overflow = '';
}

document.getElementById('designModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
});
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
});

// ============== 筛选功能 ==============
document.addEventListener('DOMContentLoaded', () => {
    const filterTabs = document.querySelectorAll('.filter-tab');
    const cards = document.querySelectorAll('.design-card');

    filterTabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const filter = tab.dataset.filter;

            filterTabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');

            cards.forEach(card => {
                if (filter === 'all' || card.dataset.series === filter) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });

            document.getElementById('noResults').style.display = 'none';
        });
    });

    // 搜索框实时搜索
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('input', () => handleSearch());
    }

    // 点击外部关闭排序下拉框
    document.addEventListener('click', (e) => {
        const sort = document.getElementById('sortDropdown');
        if (sort && !sort.contains(e.target)) {
            sort.classList.remove('open');
        }
    });
});
</script>

